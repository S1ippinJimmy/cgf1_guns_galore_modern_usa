<?xml version="1.0" encoding="utf-8"?>
<Defs>
  
  <ThingDef ParentName="BuildingBase">
    <defName>CGF1_MWP_Turret_XM250_</defName>
    <label>XM250</label>
    <description>A stationary general purpose machine gun.</description>
    <thingClass>Building_TurretGun</thingClass>
    <drawerType>MapMeshAndRealTime</drawerType>
    <graphicData>
      <texPath>CGF1/Building/M60_Base</texPath>
      <graphicClass>Graphic_Multi</graphicClass>
      <drawSize>(2,2)</drawSize>
      <damageData>
        <rect>(0.2,0.2,0.6,0.6)</rect>
      </damageData>
      <shadowData>
        <volume>(0.27,0.25,0.27)</volume>
        <offset>(0,0,0)</offset>
      </shadowData>
    </graphicData>
    <techLevel>Industrial</techLevel>
    <uiIconPath>CGF1/Building/XM250/XM250_MenuIcon</uiIconPath>
    <uiIconScale>0.90</uiIconScale>
	<minifiedDef>MinifiedThing</minifiedDef>
    <altitudeLayer>Building</altitudeLayer>
    <stealable>false</stealable>
    <rotatable>true</rotatable>
	<thingCategories>
      <li>BuildingsSecurity</li>
    </thingCategories>
    <costList>
      <Steel>25</Steel>
      <ComponentIndustrial>1</ComponentIndustrial>
	  <CGF1_MWP_XM250_>1</CGF1_MWP_XM250_>
    </costList>
    <statBases>
      <MaxHitPoints>300</MaxHitPoints>
      <Flammability>0</Flammability>
      <WorkToBuild>5000</WorkToBuild>
	  <Mass>26.5</Mass>
      <Beauty>-20</Beauty>
      <ShootingAccuracyTurret>0.97</ShootingAccuracyTurret>
    </statBases>
    <tickerType>Normal</tickerType>
    <comps>
      <li Class="CompProperties_Mannable">
        <manWorkType>Violent</manWorkType>
      </li>
      <li Class="CompProperties_Forbiddable" />

      <li Class="CompProperties_Breakdownable" />
    </comps>
    <interactionCellOffset>(0,0,-1)</interactionCellOffset>
    <hasInteractionCell>true</hasInteractionCell>
    <passability>PassThroughOnly</passability>
    <pathCost>40</pathCost>
    <fillPercent>0.4</fillPercent>
    <hasTooltip>true</hasTooltip>
    <designationCategory>CGF1_MWP_Category_GunsGalore</designationCategory>
	<!--<designatorDropdown>CGF1_MWP_Dropdown_FNMAG</designatorDropdown>-->
    <building>
      <ai_combatDangerous>true</ai_combatDangerous>
      <turretGunDef>CGF1_MWP_TurretGun_XM250_</turretGunDef>
      <turretBurstCooldownTime>2.6</turretBurstCooldownTime>
      <turretBurstWarmupTime>2.4</turretBurstWarmupTime>
	  <turretTopOffset>(0.01,0.0)</turretTopOffset>
	  <turretTopDrawSize>1.5</turretTopDrawSize>
    </building>
    <placeWorkers>
      <li>PlaceWorker_TurretTop</li>
      <li>PlaceWorker_ShowTurretRadius</li>
    </placeWorkers>
    <constructionSkillPrerequisite>5</constructionSkillPrerequisite>
    <researchPrerequisites>
      <li>CGF1_MWP_Research_T10_ModernEmplacements</li>
    </researchPrerequisites>
	<tradeTags>
			<li>CGF1_GunsGalore_ModernUSA_Turret</li>
		</tradeTags>
  </ThingDef>
  
  <ThingDef ParentName="BaseWeaponTurret">
    <defName>CGF1_MWP_TurretGun_XM250_</defName>
    <label>XM250</label>
    <description>A mounted variant of the XM250 LMG.</description>
    <graphicData>
      <texPath>CGF1/Building/XM250/XM250</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <soundInteract>Interact_Rifle</soundInteract>
    <destroyOnDrop>true</destroyOnDrop>
    <tradeability>None</tradeability>
    <useHitPoints>false</useHitPoints>
    <statBases>
      <AccuracyTouch>0.50</AccuracyTouch>
	  <AccuracyShort>0.65</AccuracyShort>
	  <AccuracyMedium>0.55</AccuracyMedium>
	  <AccuracyLong>0.45</AccuracyLong>
      <RangedWeapon_Cooldown>2.6</RangedWeapon_Cooldown>
      <DeteriorationRate>0</DeteriorationRate>
      <Mass>11</Mass>
      <Flammability>0</Flammability>
    </statBases>
    <weaponTags Inherit="false">
      <li>TurretGun</li>
    </weaponTags>
    <verbs>
      <li>
        <verbClass>Verb_Shoot</verbClass>
        <hasStandardCommand>true</hasStandardCommand>
        <defaultProjectile>CGF1_MWP_Bullet_68x51Common_Auto</defaultProjectile>
        <warmupTime>2</warmupTime>
        <range>30.9</range>
        <ticksBetweenBurstShots>5</ticksBetweenBurstShots>
		<burstShotCount>12</burstShotCount>
		<soundCast>CGF1_MWP_SFX_MG_Light_SD1</soundCast>
		<muzzleFlashScale>1</muzzleFlashScale>
      </li>
    </verbs>
  </ThingDef>
</Defs>