<?xml version="1.0" encoding="utf-8"?>
<Defs>
  
	  <ThingDef MayRequire="VanillaExpanded.VFEA" ParentName="BuildingBase">
		<defName>CGF1_MWP_Turret_RIM_116_</defName>
		<label>RIM-116 RAM</label>
		<description>An AI-operated surface-to-air missile launcher. Can fire at mortar shells and drop pods, and does not require a line of sight. Not designed to fire at ground-level targets. Requires a power source to operate.</description>
		<thingClass>Building_TurretGun</thingClass>
		<drawerType>MapMeshAndRealTime</drawerType>
		<graphicData>
		  <texPath>CGF1/Building/CIWS_Base</texPath>
		  <graphicClass>Graphic_Single</graphicClass>
		  <drawSize>(2,2)</drawSize>
		  <drawOffset>(0,0,0)</drawOffset>
		  <damageData>
			<rect>(0.2,0.2,0.6,0.6)</rect>
		  </damageData>
		  <shadowData>
			<volume>(0.27,0.25,0.27)</volume>
			<offset>(0,0,0)</offset>
		  </shadowData>
		</graphicData>
		<techLevel>Industrial</techLevel>
		<uiIconPath>CGF1/Building/RIM_116/RIM_116_MenuIcon</uiIconPath>
		<uiIconScale>0.95</uiIconScale>
		<minifiedDef>MinifiedThing</minifiedDef>
		<size>(2,2)</size>
		<altitudeLayer>Building</altitudeLayer>
		<stealable>false</stealable>
		<rotatable>true</rotatable>
		<thingCategories>
			<li>BuildingsSecurity</li>
		</thingCategories>
		<costList>
		  <Steel>400</Steel>
		  <ComponentIndustrial>35</ComponentIndustrial>
		</costList>
		<statBases>
		  <MaxHitPoints>600</MaxHitPoints>
		  <Flammability>0</Flammability>
		  <WorkToBuild>25000</WorkToBuild>
		  <Mass>5000</Mass>
		  <ShootingAccuracyTurret>0.97</ShootingAccuracyTurret>
		</statBases>
		<tickerType>Normal</tickerType>
		<comps>
			<li Class="CompProperties_Explosive">
				<wickTicks>300</wickTicks>
				<explosiveRadius>5.9</explosiveRadius>
				<explosiveDamageType>Bomb</explosiveDamageType>
				<chanceNeverExplodeFromDamage>0.1</chanceNeverExplodeFromDamage>
			</li>
			<li Class="CompProperties_Forbiddable" />
			<li Class="CompProperties_Power">
				<compClass>CompPowerTrader</compClass>
				<basePowerConsumption>300</basePowerConsumption>
			</li>
			<li Class="CompProperties_Flickable" />
			<li Class="CompProperties_Breakdownable" />
			<li MayRequire="VanillaExpanded.VFEA" Class="VFEAncients.CompProperties_SolarPowerUp" />
			<!--<li Class="CompProperties_Refuelable">
				<fuelLabel>Shots until barrel change</fuelLabel>
				<fuelGizmoLabel>Barrel durability</fuelGizmoLabel>
				<outOfFuelMessage>Needs new barrel</outOfFuelMessage>
				<fuelFilter><thingDefs><li>Steel</li></thingDefs></fuelFilter>
				<fuelCapacity>250</fuelCapacity>
				<fuelMultiplier>0.1</fuelMultiplier>
				<initialFuelPercent>1</initialFuelPercent>
				<autoRefuelPercent>0.5</autoRefuelPercent>
				<showFuelGizmo>true</showFuelGizmo>
				<minimumFueledThreshold>1</minimumFueledThreshold>
				<factorByDifficulty>true</factorByDifficulty>
				<consumeFuelOnlyWhenUsed>true</consumeFuelOnlyWhenUsed>
				<fuelIconPath>UI/Overlays/Barrel</fuelIconPath>
			</li>-->
		</comps>
		<passability>PassThroughOnly</passability>
		<pathCost>50</pathCost>
		<fillPercent>0.5</fillPercent>
		<hasTooltip>true</hasTooltip>
		<designationCategory>CGF1_MWP_Category_GunsGalore</designationCategory>
		<!--<designatorDropdown>CGF1_MWP_Dropdown_RWS</designatorDropdown>-->
		<building>
		  <ai_combatDangerous>true</ai_combatDangerous>
		  <combatPower>120</combatPower> <!-- same as a scavenger -->
		  <turretGunDef>CGF1_MWP_TurretGun_RIM_116_</turretGunDef>
		  <turretTopOffset>(0.0,0.0)</turretTopOffset>
		  <turretTopDrawSize>6.00</turretTopDrawSize>
		</building>
		<placeWorkers>
		  <li>PlaceWorker_TurretTop</li>
		  <li>PlaceWorker_ShowTurretRadius</li>
		</placeWorkers>
		<constructionSkillPrerequisite>8</constructionSkillPrerequisite>
		<researchPrerequisites>
		  <li>CGF1_MWP_Research_T10_ModernEmplacements</li>
		</researchPrerequisites>
		<tradeTags>
			<li>CGF1_GunsGalore_X_RWS_Turret</li>
		</tradeTags>
	</ThingDef>
	
	<ThingDef MayRequire="VanillaExpanded.VFEA" ParentName="BaseWeaponTurret">
		<defName>CGF1_MWP_TurretGun_RIM_116_</defName>
		<label>RIM-116 RAM</label>
		<description>RIM-116 RAM.</description>
		<graphicData>
		  <texPath>CGF1/Building/RIM_116/RIM_116</texPath>
		  <graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<soundInteract>Interact_Rifle</soundInteract>
		<destroyOnDrop>true</destroyOnDrop>
		<tradeability>None</tradeability>
		<useHitPoints>false</useHitPoints>
		<statBases>
		  <AccuracyTouch>0.40</AccuracyTouch>
		  <AccuracyShort>0.80</AccuracyShort>
		  <AccuracyMedium>0.80</AccuracyMedium>
		  <AccuracyLong>0.95</AccuracyLong>
		  <RangedWeapon_Cooldown>3</RangedWeapon_Cooldown>
		  <DeteriorationRate>0</DeteriorationRate>
		  <Mass>5000</Mass>
		  <Flammability>0</Flammability>
		</statBases>
		<weaponTags Inherit="false">
			<li>TurretGun</li>
		</weaponTags>
		<verbs>
			<li>
				<verbClass>Verb_Shoot</verbClass>
				<hasStandardCommand>true</hasStandardCommand>
				<defaultProjectile>CGF1_MWP_Bullet_127mm_RIM116_</defaultProjectile>
				<warmupTime>0</warmupTime>
				<range>120.0</range>
				<soundCast>CGF1_MWP_SFX_Launcher_Javelin</soundCast>
				<soundCastTail>GunTail_Heavy</soundCastTail>
				<muzzleFlashScale>20</muzzleFlashScale>
				<isPrimary>true</isPrimary>
			    <defaultCooldownTime>10</defaultCooldownTime>
				<!--<consumeFuelPerShot>1</consumeFuelPerShot>-->
				<forcedMissRadius>0.9</forcedMissRadius>
				<targetParams>
					<canTargetBuildings>false</canTargetBuildings>
					<canTargetLocations>true</canTargetLocations>
					<canTargetPawns>false</canTargetPawns>
				</targetParams>
			</li>
			<li MayRequire="VanillaExpanded.VFEA">
				<verbClass>Verb_Shoot</verbClass>
				<hasStandardCommand>false</hasStandardCommand>
				<label>point-defense</label>
				<defaultProjectile>CGF1_MWP_Bullet_127mm_RIM116_</defaultProjectile>
				<warmupTime>0</warmupTime>
				<range>120.9</range>
				<burstShotCount>1</burstShotCount>
				<ticksBetweenBurstShots>0</ticksBetweenBurstShots>
				<soundCast>CGF1_MWP_SFX_Launcher_Javelin</soundCast>
				<soundCastTail>GunTail_Heavy</soundCastTail>
				<muzzleFlashScale>20</muzzleFlashScale>
				<requireLineOfSight>false</requireLineOfSight>
				<isPrimary>false</isPrimary>
			    <defaultCooldownTime>5</defaultCooldownTime>
				<!--<consumeFuelPerShot>1</consumeFuelPerShot>-->
				<forcedMissRadius>0.9</forcedMissRadius>
				<targetParams>
					<canTargetBuildings>false</canTargetBuildings>
					<canTargetLocations>true</canTargetLocations>
					<canTargetPawns>false</canTargetPawns>
				</targetParams>
			</li>
		</verbs>
		<modExtensions>
				<li Class="MuzzleFlash.MuzzleFlashProps" MayRequire="issaczhuang.muzzleflash">
					<def>MF_StandardMuzzleFalsh</def>
					<drawSize>(2,2)</drawSize>
					<offsets>
						<li>(2.00,0.00)</li>
					</offsets>
				</li>
		</modExtensions>
	  </ThingDef>
	
	
</Defs>