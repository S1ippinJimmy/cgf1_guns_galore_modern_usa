<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<ThingDef MayRequire="VanillaExpanded.VWENL" ParentName="CGF1_MWP_Grenade">
		<defName>CGF1_MWP_M7A3_CS_</defName>
		<label>M7A3 CS Grenade</label>
		<description>The M7A3 is an American riot control grenade that is filled with 2-chlorobenzalmalononitrile, more commonly known as CS gas. The M7A3 uses the same mixture as the earlier M7A2 variant but the CS in the M7A3 is pelletized instead of being stored as gelatin capsules. The gas released by the grenade is intended to debilitate and incapacitate unprotected targets without causing lethal harm.</description>
		<graphicData>
			<texPath>CGF1/Gun/M7A3_CS</texPath>
			<drawSize>0.75</drawSize>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<uiIconScale>1.3</uiIconScale>
		<recipeMaker>
			<recipeUsers>
				<li>CGF1_MWP_Building_Gunsmith</li>
			</recipeUsers>
			<researchPrerequisite>CGF1_MWP_Research_T10_ModernFirearms</researchPrerequisite>
		</recipeMaker>
		<techLevel>Industrial</techLevel>
		<soundInteract>Interact_Grenade</soundInteract>
		<costList>
			<Steel>20</Steel>
			<Chemfuel>50</Chemfuel>
		</costList>
		<statBases>
			<WorkToMake>10000</WorkToMake>
			<Mass>1</Mass>
			<RangedWeapon_Cooldown>2.66</RangedWeapon_Cooldown>
		</statBases>
		<weaponTags>
			<li>CGF1_Grenade_Tox</li>
		</weaponTags>
		<tradeTags>
			<li>CGF1_GunsGalore_ModernUSA</li>
			<li>CGF1_GunsGalore_ModernUSA_Grenade</li>
		</tradeTags>
		<verbs>
			<li>
				<label>throw gas grenade</label>
				<verbClass>Verb_LaunchProjectile</verbClass>
				<hasStandardCommand>true</hasStandardCommand>
				<defaultProjectile>CGF1_MWP_Projectile_M7A3_CS</defaultProjectile>
				<range>12.9</range>
				<warmupTime>1.5</warmupTime>
				<noiseRadius>4</noiseRadius>
				<forcedMissRadius>1.9</forcedMissRadius>
				<soundCast>CGF1_MWP_SFX_Grenade_Throw</soundCast>
				<targetParams>
					<canTargetLocations>true</canTargetLocations>
				</targetParams>
				<rangedFireRulepack>Combat_RangedFire_Thrown</rangedFireRulepack>
			</li>
		</verbs>
		<generateCommonality>0.10</generateCommonality> <!-- Average -->
		<possessionCount>1</possessionCount> <!-- Possession -->
		<thingSetMakerTags>
			<li>CGF1_GunsGalore_RewardAncient_Common</li>
		</thingSetMakerTags>
	</ThingDef>
	<ThingDef MayRequire="VanillaExpanded.VWENL">
		<defName>CGF1_MWP_Projectile_M7A3_CS</defName>
		<label>M7A3 CS Grenade</label>
		<category>Projectile</category>
		<altitudeLayer>Projectile</altitudeLayer>
		<tickerType>Normal</tickerType>
		<useHitPoints>False</useHitPoints>
		<neverMultiSelect>True</neverMultiSelect>
		<thingClass>Projectile_Explosive</thingClass>
		<graphicData>
		  <texPath>CGF1/Projectile/M7A3_CS</texPath>
		  <graphicClass>Graphic_Single</graphicClass>
		  <shaderType>Transparent</shaderType>
		  <drawSize>0.63</drawSize>
		</graphicData>
		<projectile>
		  <damageDef>Smoke</damageDef>
		  <explosionDelay>100</explosionDelay>
		  <postExplosionSpawnThingDef>CGF1_MWP_CSGasCloud</postExplosionSpawnThingDef>
		  <postExplosionSpawnChance>1</postExplosionSpawnChance>
      	  <postExplosionSpawnThingCount>1</postExplosionSpawnThingCount>
		  <speed>12</speed>
		  <explosionRadius>3.9</explosionRadius>
		  <arcHeightFactor>2</arcHeightFactor>
		  <shadowSize>0.4</shadowSize>
		  <applyDamageToExplosionCellsNeighbors>true</applyDamageToExplosionCellsNeighbors>
		</projectile>
  </ThingDef>
	
	
</Defs>