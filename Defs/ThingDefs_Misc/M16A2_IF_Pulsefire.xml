				<Crafting>6</Crafting>
			</skillRequirements>
		</recipeMaker>
		<costList>
			<Steel>70</Steel>
			<ComponentIndustrial>9</ComponentIndustrial>
		</costList>
		<statBases>
			<WorkToMake>50000</WorkToMake>
			<Mass>5.15</Mass>
			<AccuracyTouch>0.60</AccuracyTouch>
			<AccuracyShort>0.70</AccuracyShort>
