		<graphicData>
			<texPath>CGF1/Gun/M16A2_IF_Pulsefire</texPath>
			<drawSize>1.03</drawSize>
		</graphicData>
		<recipeMaker>
			<recipeUsers>
				<li>CGF1_MWP_Building_Gunsmith</li>
			</recipeUsers>
			<researchPrerequisite>CGF1_MWP_Research_T10_ModernFirearms</researchPrerequisite>
