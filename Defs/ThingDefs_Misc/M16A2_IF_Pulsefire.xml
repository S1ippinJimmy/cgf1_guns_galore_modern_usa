				<verbClass>VEF.Weapons.Verb_Shoot</verbClass>
				<hasStandardCommand>true</hasStandardCommand>
				<defaultProjectile>CGF1_MWP_Projectile_Flamethrower_Pulsefire</defaultProjectile>
