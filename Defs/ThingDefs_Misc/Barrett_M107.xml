<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<ThingDef ParentName="CGF1_MWP_Rifle_SemiAutoAMR_T0">
		<defName>CGF1_MWP_Barrett_M107_</defName>
		<label>Barrett M107</label>
		<description>Caliber: 12.7x99mm NATO. 10-round detachable mag. Semi-Automatic.</description>
		<graphicData>
			<texPath>CGF1/Gun/Barrett_M107</texPath>
			<drawSize>1.20</drawSize>
		</graphicData>
		<recipeMaker>
			<recipeUsers>
				<li>CGF1_MWP_Building_Gunsmith</li>
			</recipeUsers>
			<researchPrerequisite>CGF1_MWP_Research_T10_ModernFirearms</researchPrerequisite>
			<skillRequirements>
				<Crafting>8</Crafting>
			</skillRequirements>
		</recipeMaker>
		<costList>
			<Steel>160</Steel>
			<ComponentIndustrial>16</ComponentIndustrial>
		</costList>
		<statBases>
			<WorkToMake>70000</WorkToMake>
			<Mass>18</Mass>
			<AccuracyTouch>0.30</AccuracyTouch>
			<AccuracyShort>0.45</AccuracyShort>
			<AccuracyMedium>0.75</AccuracyMedium>
			<AccuracyLong>0.90</AccuracyLong>
			<RangedWeapon_Cooldown>3</RangedWeapon_Cooldown>
		</statBases>
		<equippedAngleOffset>40</equippedAngleOffset>
		<weaponTags>
			<li>CGF1_SniperRifle</li>
			<li>CGF1_SniperRifle_Advanced</li>
		</weaponTags>
		<weaponClasses>
			<li>LongShots</li>
			<li>RangedHeavy</li>
		</weaponClasses>
		<tradeTags>
			<li>CGF1_GunsGalore_ModernUSA</li>
			<li>CGF1_GunsGalore_ModernUSA_Sniper</li>
		</tradeTags>
		<verbs>
			<li>
				<verbClass>Verb_Shoot</verbClass>
				<hasStandardCommand>true</hasStandardCommand>
				<defaultProjectile>CGF1_MWP_Bullet_127x99mmNATO_Sniper</defaultProjectile>
				<warmupTime>4.6</warmupTime>
				<range>44.9</range>
				<soundCast>CGF1_MWP_SFX_Rifle_Heavy1</soundCast>
				<soundCastTail>GunTail_Heavy</soundCastTail>
				<muzzleFlashScale>14</muzzleFlashScale>
			</li>
		</verbs>
		<tools>
			<li>
				<label>stock</label>
				<capacities>
					<li>Blunt</li>
				</capacities>
				<power>10</power>
				<cooldownTime>2</cooldownTime>
			</li>
			<li>
				<label>barrel</label>
				<capacities>
					<li>Blunt</li>
					<li>Poke</li>
				</capacities>
				<power>9</power>
				<cooldownTime>2</cooldownTime>
			</li>
		</tools>
		<modExtensions>
			<li Class="MuzzleFlash.MuzzleFlashProps" MayRequire="issaczhuang.muzzleflash">
				<def>MF_StandardMuzzleFalsh</def>
				<drawSize>(2,2)</drawSize>
				<offsets>
					<li>(0.57,0.08)</li>
				</offsets>
			</li>
		</modExtensions>
		<generateCommonality>0.5</generateCommonality> <!-- Abundant -->
		<thingSetMakerTags>
			<li>CGF1_GunsGalore_RewardAncient_Common</li>
		</thingSetMakerTags>
	</ThingDef>
	
