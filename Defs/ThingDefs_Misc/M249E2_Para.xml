<Defs>

	<ThingDef ParentName="CGF1_MWP_LMG_BeltFed_T1">
		<defName>CGF1_MWP_M249E2_Para_</defName>
		<label>M249E2 Para</label>
		<description>Caliber: 5.56x45mm NATO. 200-round bullet link. Select-Fire.</description>
		<graphicData>
